<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>High-End Game Menu Interface</title>
    <!-- Google Fonts for crisp, stylized gaming typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* ==========================================================================
           THEME VARIABLES (Easily customizable for any interest)
           ========================================================================== */
        :root {
            --bg-dark: #0a0a0f;
            --bg-card: #12121a;
            --primary-glow: #00f0ff; /* Electric Blue */
            --secondary-glow: #bd00ff; /* Neon Purple */
            --text-main: #ffffff;
            --text-muted: #8af9ff;
            --font-display: 'Orbitron', sans-serif;
            --font-body: 'Rajdhani', sans-serif;
        }

        /* Global Reset & Base Styles */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            background-color: var(--bg-dark);
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(20, 20, 35, 0.8) 0%, rgba(10, 10, 15, 1) 100%),
                linear-gradient(rgba(18, 18, 26, 0.3) 50%, rgba(0, 0, 0, 0.5) 50%);
            background-size: 100% 100%, 100% 4px; /* Scanline effect */
            color: var(--text-main);
            font-family: var(--font-body);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
            padding: 20px;
        }

        /* Ambient Background Grid Overlay */
        body::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                linear-gradient(to right, rgba(0, 240, 255, 0.03) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(0, 240, 255, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: -1;
            pointer-events: none;
        }

        /* ==========================================================================
           2. MAIN GAME ARENA CONTAINER (With Neon Pulse Box-Shadow)
           ========================================================================== */
        .game-container {
            background: linear-gradient(135deg, var(--bg-card) 0%, #161622 100%);
            border: 2px solid var(--primary-glow);
            border-radius: 12px;
            width: 100%;
            max-width: 1024px;
            padding: 40px;
            position: relative;
            box-shadow: 
                0 0 20px rgba(0, 240, 255, 0.2),
                inset 0 0 15px rgba(0, 240, 255, 0.1);
            animation: pulseGlow 4s infinite alternate ease-in-out;
            overflow: hidden;
        }

        /* Decorative UI Corners for Sci-Fi Aesthetic */
        .game-container::before, .game-container::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border: 3px solid var(--secondary-glow);
            pointer-events: none;
        }
        .game-container::before { top: -2px; left: -2px; border-right: none; border-bottom: none; }
        .game-container::after { bottom: -2px; right: -2px; border-left: none; border-top: none; }

        /* Pulse Animation for the Container Grid */
        @keyframes pulseGlow {
            0% {
                box-shadow: 0 0 20px rgba(0, 240, 255, 0.25), inset 0 0 15px rgba(0, 240, 255, 0.1);
                border-color: var(--primary-glow);
            }
            100% {
                box-shadow: 0 0 35px rgba(189, 0, 255, 0.4), inset 0 0 25px rgba(189, 0, 255, 0.15);
                border-color: var(--secondary-glow);
            }
        }

        /* ==========================================================================
           4. TYPOGRAPHY & HEADER
           ========================================================================== */
        .menu-header {
            text-align: center;
            margin-bottom: 40px;
            position: relative;
        }

        .menu-subtitle {
            font-family: var(--font-body);
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 6px;
            color: var(--text-muted);
            margin-bottom: 5px;
            text-shadow: 0 0 5px rgba(0, 240, 255, 0.5);
        }

        .menu-title {
            font-family: var(--font-display);
            font-weight: 900;
            font-size: 3.5rem;
            text-transform: uppercase;
            letter-spacing: 4px;
            background: linear-gradient(to right, var(--text-main) 30%, var(--primary-glow) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 2px 8px rgba(0, 240, 255, 0.3));
        }

        /* ==========================================================================
           3. INTERACTIVE ELEMENTS / UI TILES
           ========================================================================== */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .ui-tile {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(0, 240, 255, 0.2);
            padding: 25px;
            border-radius: 8px;
            text-align: center;
            cursor: pointer;
            position: relative;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .ui-tile .tile-icon {
            font-size: 2rem;
            color: var(--primary-glow);
            transition: all 0.3s ease;
        }

        .ui-tile h3 {
            font-family: var(--font-display);
            font-size: 1.2rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .ui-tile p {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.6);
        }

        /* Interactive Tile Hover Effects */
        .ui-tile:hover {
            transform: translateY(-5px);
            background: rgba(0, 240, 255, 0.05);
            border-color: var(--primary-glow);
            box-shadow: 0 0 15px rgba(0, 240, 255, 0.3);
        }

        .ui-tile:hover .tile-icon {
            color: #ffffff;
            text-shadow: 0 0 10px var(--primary-glow);
        }

        /* Action Buttons Wrapper */
        .action-flex {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-width: 400px;
            margin: 0 auto;
        }

        /* Modern Sleek Action Buttons */
        .btn-action {
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-main);
            background: linear-gradient(90deg, rgba(189, 0, 255, 0.2) 0%, rgba(0, 240, 255, 0.2) 100%);
            border: 1px solid var(--primary-glow);
            padding: 16px 30px;
            border-radius: 4px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.25s ease;
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.1);
        }

        /* Button Hover and Active states */
        .btn-action:hover {
            background: linear-gradient(90deg, var(--secondary-glow) 0%, var(--primary-glow) 100%);
            box-shadow: 0 0 25px rgba(0, 240, 255, 0.6);
            transform: scale(1.03);
            letter-spacing: 4px;
        }

        .btn-action:active {
            transform: scale(0.98);
            filter: brightness(0.8);
        }

        /* Visual Accent: Sidebar Status Panel */
        .status-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 20px;
            margin-top: 40px;
            font-size: 0.85rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.5);
        }

        .status-online {
            color: var(--primary-glow);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-online::before {
            content: '';
            display: inline-block;
            width: 8px;
            height: 8px;
            background-color: var(--primary-glow);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--primary-glow);
        }

        /* Responsive scaling */
        @media (max-width: 768px) {
            .menu-title { font-size: 2.5rem; }
            .game-container { padding: 20px; }
        }
    </style>
</head>
<body>

    <!-- Main Game Arena Container -->
    <main class="game-container">
        
        <!-- Header -->
        <header class="menu-header">
            <div class="menu-subtitle">System Status: Active</div>
            <h1 class="menu-title">CORE_INTERFACE</h1>
        </header>

        <!-- Interactive Tech Content Grid -->
        <section class="menu-grid">
            <div class="ui-tile">
                <div class="tile-icon">⌬</div>
                <h3>Campaign</h3>
                <p>Continue your primary narrative journey.</p>
            </div>
            
            <div class="ui-tile">
                <div class="tile-icon">⎔</div>
                <h3>Multiplayer</h3>
                <p>Connect and compete globally.</p>
            </div>

            <div class="ui-tile">
                <div class="tile-icon">⚙</div>
                <h3>Loadout</h3>
                <p>Modify weapon parameters and visuals.</p>
            </div>
        </section>

        <!-- High-End Arcade Menu Navigation -->
        <nav class="action-flex">
            <button class="btn-action">Launch Session</button>
            <button class="btn-action" style="--primary-glow: var(--secondary-glow);">System Settings</button>
        </nav>

        <!-- UI Footer Meta Element -->
        <footer class="status-bar">
            <div>Server: US-EAST_NODE_09</div>
            <div class="status-online">System Connected</div>
        </footer>

    </main>

</body>
</html>